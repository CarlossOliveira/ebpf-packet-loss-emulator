PROJECT_NAME = "ebpf-packet-loss-emulator"

INPUT = src
RECURSIVE = YES

FILE_PATTERNS = *.c *.h

EXCLUDE += src/kernel-space/include/vmlinux.h

# -----------------------------------------------------------------------------
# Documentation extraction
# -----------------------------------------------------------------------------

EXTRACT_ALL = YES
EXTRACT_PRIVATE = YES
EXTRACT_STATIC = YES
EXTRACT_LOCAL_CLASSES = YES
EXTRACT_LOCAL_METHODS = YES
EXTRACT_ANON_NSPACES = YES

HIDE_UNDOC_MEMBERS = NO
HIDE_UNDOC_CLASSES = NO

WARN_IF_UNDOCUMENTED = YES
WARN_AS_ERROR = YES

# -----------------------------------------------------------------------------
# HTML generation
# -----------------------------------------------------------------------------

GENERATE_HTML = YES
GENERATE_LATEX = NO

HTML_OUTPUT = docs/source/api

FULL_SIDEBAR = YES
HTML_DYNAMIC_SECTIONS = YES
GENERATE_TREEVIEW = YES

HTML_HEADER = docs/assets/doxygen/header.html

HTML_EXTRA_FILES = \
    docs/assets/doxygen/extensions/doxygen-awesome-darkmode-toggle.js \
    docs/assets/doxygen/extensions/doxygen-awesome-paragraph-link.js \
    docs/assets/doxygen/extensions/doxygen-awesome-interactive-toc.js

HTML_EXTRA_STYLESHEET = \
    docs/assets/doxygen/theme/doxygen-awesome.css \
    docs/assets/doxygen/theme/doxygen-awesome-sidebar-only.css \
    docs/assets/doxygen/theme/doxygen-awesome-sidebar-only-darkmode-toggle.css

# -----------------------------------------------------------------------------
# Source code navigation
# -----------------------------------------------------------------------------

SOURCE_BROWSER = YES
INLINE_SOURCES = YES
REFERENCES_LINK_SOURCE = YES

VERBATIM_HEADERS = YES

# -----------------------------------------------------------------------------
# Graphviz
# -----------------------------------------------------------------------------

HAVE_DOT = YES
DOT_NUM_THREADS = 0

DOT_IMAGE_FORMAT = svg

INTERACTIVE_SVG = YES

# -----------------------------------------------------------------------------
# Function call graphs
# -----------------------------------------------------------------------------

CALL_GRAPH = YES
CALLER_GRAPH = YES

REFERENCED_BY_RELATION = YES
REFERENCES_RELATION = YES

# -----------------------------------------------------------------------------
# Include dependency graphs
# -----------------------------------------------------------------------------

INCLUDE_GRAPH = YES
INCLUDED_BY_GRAPH = YES

# -----------------------------------------------------------------------------
# Directory dependency graphs
# -----------------------------------------------------------------------------

DIRECTORY_GRAPH = YES

# -----------------------------------------------------------------------------
# Type / struct / enum graphs
# -----------------------------------------------------------------------------

CLASS_GRAPH = YES
COLLABORATION_GRAPH = YES

UML_LOOK = YES
TEMPLATE_RELATIONS = YES

# -----------------------------------------------------------------------------
# Graph size limits
# -----------------------------------------------------------------------------

DOT_GRAPH_MAX_NODES = 100
MAX_DOT_GRAPH_DEPTH = 0

# -----------------------------------------------------------------------------
# C specific improvements
# -----------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C = YES

TYPEDEF_HIDES_STRUCT = NO

SORT_MEMBER_DOCS = YES
SORT_BRIEF_DOCS = YES
SORT_BY_SCOPE_NAME = YES
